# Copy to .env.local and fill in. .env.local is gitignored — never commit it.

# Backend selection: 'true' runs the app entirely on the in-browser localStorage
# shim (no Firebase needed). 'false' uses Firestore + Storage.
VITE_USE_LOCAL_STORAGE=true

# Set to 'true' to use local Firebase emulators (Firestore :8080, Storage :9199)
# instead of a live project.
VITE_USE_FIREBASE_EMULATOR=false

# Firebase web app config (Firebase console → Project settings → Your apps).
# Required when VITE_USE_LOCAL_STORAGE=false and not using the emulator.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
